# Environment Variables — Copy to .env and fill in your values

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=nil_user
POSTGRES_PASSWORD=nil_password
POSTGRES_DB=next_in_line
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Decay Scheduler ──────────────────────────────────────────
# How often (in ms) the decay scheduler polls for expired promotions
DECAY_POLL_INTERVAL_MS=300000

# ─── Frontend ─────────────────────────────────────────────────
# Used by Vite dev server
VITE_API_BASE_URL=http://localhost:4000/api
